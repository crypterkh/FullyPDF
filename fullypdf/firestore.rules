rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return request.auth.token.email_verified == true; }
    function isOwner(userId) { return request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9._~%\\-\\+]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // User validation
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'createdAt'])
        && data.uid is string && data.uid.size() <= 128 && data.uid == request.auth.uid
        && data.createdAt == request.time
        && (
          !('email' in data) || (data.email is string && data.email.size() <= 256)
        )
        && (
          !('displayName' in data) || (data.displayName is string && data.displayName.size() <= 128)
        )
        && (
          !('photoURL' in data) || (data.photoURL is string && data.photoURL.size() <= 50000)
        )
        && (
          !('lastLoginAt' in data) || (data.lastLoginAt == request.time)
        )
        && (
          !('theme' in data) || (data.theme is string && data.theme.size() <= 32)
        );
    }

    // Users Collection
    match /users/{userId} {
      allow read: if isSignedIn() && isOwner(userId);
      allow create: if isSignedIn() && isValidId(userId) && isOwner(userId)
        && isValidUser(incoming()) && incoming().keys().size() <= 7;
      allow update: if isSignedIn() && isValidId(userId) && isOwner(userId)
        && incoming().uid == existing().uid
        && incoming().createdAt == existing().createdAt
        && (
          incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'lastLoginAt', 'theme'])
        )
        && (
          !('displayName' in incoming()) || (incoming().displayName is string && incoming().displayName.size() <= 128)
        )
        && (
          !('photoURL' in incoming()) || (incoming().photoURL is string && incoming().photoURL.size() <= 50000)
        )
        && (
          !('lastLoginAt' in incoming()) || (incoming().lastLoginAt == request.time)
        )
        && (
          !('theme' in incoming()) || (incoming().theme is string && incoming().theme.size() <= 32)
        );
    }

    match /users/{userId}/history/{historyId} {
      allow read, delete: if isSignedIn() && isOwner(userId);
      allow create: if isSignedIn() && isOwner(userId) && isValidId(historyId)
        && incoming().keys().hasAll(['filename', 'operation', 'timestamp'])
        && incoming().filename is string && incoming().filename.size() <= 512
        && incoming().operation is string && incoming().operation.size() <= 128
        && incoming().timestamp is number
        && (!('localId' in incoming()) || (incoming().localId is string && incoming().localId.size() <= 128));
      allow update: if isSignedIn() && isOwner(userId) && isValidId(historyId)
        && incoming().diff(existing()).affectedKeys().hasOnly(['filename', 'operation', 'timestamp', 'localId']);
    }
  }
}
